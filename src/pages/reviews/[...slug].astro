			gap: 8px;
			justify-content: space-between;
		}

		.share-dialog-controls button:not(.share-generate-button) {
			min-width: 34px;
			min-height: 34px;
			padding: 0 10px;
			font-size: 13px;
		}

		.share-dialog-controls .share-generate-button {
			min-height: 36px;
			padding: 0 14px;
			font-size: 13px;
		}

		.share-preview-viewport {
			padding: 12px;
		}
