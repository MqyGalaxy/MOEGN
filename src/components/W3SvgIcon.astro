---
interface Props {
	name: 'calendar' | 'trophy' | 'anime' | 'game' | 'book' | 'music' | 'play' | 'copy' | 'share' | 'external' | 'chevron-down' | 'tool';
}

const { name } = Astro.props;
---

<svg class="w3-svg-icon" viewBox="0 0 24 24" aria-hidden="true">
	{name === 'calendar' ? (
		<>
			<path d="M7 3v3M17 3v3M4.5 9.5h15" />
			<rect x="4.5" y="5" width="15" height="15.5" rx="2.5" />
			<path d="M8 13h.01M12 13h.01M16 13h.01M8 17h.01M12 17h.01" />
		</>
	) : null}
	{name === 'trophy' ? (
		<>
			<path d="M8 4h8v4.5a4 4 0 0 1-8 0V4Z" />
			<path d="M8 6H5.5A2.5 2.5 0 0 0 8 10.5M16 6h2.5A2.5 2.5 0 0 1 16 10.5M12 12.5V17M9 20h6M10 17h4" />
		</>
	) : null}
	{name === 'anime' ? (
		<>
			<rect x="4.5" y="6.5" width="15" height="11" rx="2.5" />
			<path d="m8.2 3.8 2.4 2.7M15.8 3.8l-2.4 2.7M10.5 10l4 2.2-4 2.2V10ZM9 20h6" />
		</>
	) : null}
	{name === 'game' ? (
		<>
			<path d="M8.05 5.95h7.9c2.12 0 3.94 1.51 4.35 3.6l1.22 6.15a2.98 2.98 0 0 1-5.14 2.55l-1.76-2.1H9.38l-1.76 2.1a2.98 2.98 0 0 1-5.14-2.55l1.22-6.15a4.43 4.43 0 0 1 4.35-3.6Z" />
			<path d="M7.45 10.55V14M5.72 12.28h3.45" />
			<path d="M16.75 10.35h.01M15.3 11.8h.01M18.2 11.8h.01M16.75 13.25h.01" />
		</>
	) : null}
	{name === 'book' ? (
		<>
			<rect x="5.2" y="3.8" width="13.6" height="16.4" rx="2.2" />
			<path d="M8.3 7.2h7.4M8.3 10.4h7.4M8.3 13.6h2.7M13.2 13.6h2.5M8.3 16.8h4.8" />
		</>
	) : null}
	{name === 'music' ? (
		<>
			<path d="M8.4 17.3a2.35 2.35 0 1 1-1.25-2.08V7.4l9.7-1.7v8.72a2.35 2.35 0 1 1-0-0.28V8.15L7.15 9.95" />
		</>
	) : null}
	{name === 'play' ? (
		<path class="is-solid" d="M8.2 6.85c0-1.3 1.43-2.1 2.53-1.4l7.32 4.65c1.04.66 1.04 2.18 0 2.84l-7.32 4.65c-1.1.7-2.53-.1-2.53-1.4V6.85Z" />
	) : null}
	{name === 'copy' ? (
		<>
			<rect x="8" y="8" width="11" height="11" rx="2" />
			<path d="M5 15.5V6.5A1.5 1.5 0 0 1 6.5 5h9" />
		</>
	) : null}
	{name === 'share' ? (
		<>
			<circle cx="18" cy="5.5" r="2.5" />
			<circle cx="6" cy="12" r="2.5" />
			<circle cx="18" cy="18.5" r="2.5" />
			<path d="m8.2 10.8 7.6-4.1M8.2 13.2l7.6 4.1" />
		</>
	) : null}
	{name === 'external' ? (
		<>
			<path d="M14 5h5v5M19 5l-8 8" />
			<path d="M12 7H7.5A2.5 2.5 0 0 0 5 9.5v7A2.5 2.5 0 0 0 7.5 19h7A2.5 2.5 0 0 0 17 16.5V12" />
		</>
	) : null}
	{name === 'chevron-down' ? (
		<path d="m7 10 5 5 5-5" />
	) : null}
	{name === 'tool' ? (
		<>
			<path d="M4 7h16M4 17h16" />
			<circle cx="9" cy="7" r="2.25" class="is-solid" />
			<circle cx="15" cy="17" r="2.25" class="is-solid" />
		</>
	) : null}
</svg>

<style>
	.w3-svg-icon {
		display: block;
		width: 100%;
		height: 100%;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.w3-svg-icon .is-solid {
		fill: currentColor;
		stroke: none;
	}
</style>
