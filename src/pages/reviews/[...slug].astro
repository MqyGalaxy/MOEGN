---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import W3SvgIcon from '../../components/W3SvgIcon.astro';
import { getImage } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import {
	getReviewCategoryHref,
	getReviewSubCategorCategories,
	matchesReviewCategory,
	standardReviewCategories,
} from '../../data/reviewCategories';
import { getRelatedReviewWorkSlugs } from '../../data/relatedReviews';
import { getSortedOtherTags } from '../../data/reviewTags';

export async function getStaticPaths() {
	const reviews = await getCollection('reviews');

	return reviews.map((review) => ({
		params: { slug: review.slug },
		props: { review },
	}));
}

const { review } = Astro.props as { review: CollectionEntry<'reviews'> };
const { Content } = await review.render();
const previewAssetModules = import.meta.glob('../../assets/**/*.{avif,gif,jpeg,jpg,png,webp}', {
	eager: true,
	import: 'default',
});
const moeqyGirlModules = import.meta.glob('../../assets/moeqyGirl/*_noBackground.webp', {
	eager: true,
	import: 'default',
});
const moeqyGirlImages = Object.values(moeqyGirlModules).map((asset) => (asset as ImageMetadata).src);
const previewAssets = new Map<string, ImageMetadata>(
	Object.entries(previewAssetModules).map(([assetPath, asset]) => {
		const normalizedPath = assetPath.replace('../../assets/', 'src/assets/').replaceAll('\\', '/');

		return [normalizedPath, asset as ImageMetadata];
	}),
);
const allReviews = await getCollection('reviews');
const getWorkPath = (slug: string) => slug.split('/').slice(0, -1).join('/');
const workPath = getWorkPath(review.slug);
const latestReviewByWork = new Map<string, CollectionEntry<'reviews'>>();

for (const entry of allReviews) {
	const entryWorkPath = getWorkPath(entry.slug);
	const latestEntry = latestReviewByWork.get(entryWorkPath);

	if (!latestEntry || entry.data.publishedAt.valueOf() > latestEntry.data.publishedAt.valueOf()) {
		latestReviewByWork.set(entryWorkPath, entry);
	}
}

const latestReview = latestReviewByWork.get(workPath);
const isOutdatedReview = Boolean(latestReview && latestReview.slug !== review.slug);
const publishedDate = review.data.publishedAt.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
const createPreviewVideoSrc = (videoSrc?: string) => {
	if (!videoSrc) return '';

	const [urlWithoutHash, hash] = videoSrc.split('#');
	const [baseUrl, query = ''] = urlWithoutHash.split('?');
	const params = new URLSearchParams(query);

	params.set('autoplay', '1');
	params.set('muted', '0');
	params.set('mute', '0');
	params.set('muted_play', '0');

	return `${baseUrl}?${params.toString()}${hash ? `#${hash}` : ''}`;
};
const resolvePreviewImage = async (imageSrc: string) => {
	const normalizedSrc = imageSrc.replaceAll('\\', '/').replace(/^\/+/, '');
	const localAsset = previewAssets.get(normalizedSrc);

	if (!localAsset) return imageSrc;

	const optimizedImage = await getImage({ src: localAsset });

	return optimizedImage.src;
};
const previewImages = await Promise.all(review.data.previewImages.slice(0, 4).map(resolvePreviewImage));
const previewPrimaryImage = previewImages[0] ?? review.data.imgSrc;
const previewVideoCover = review.data.previewVideoCover ? await resolvePreviewImage(review.data.previewVideoCover) : previewPrimaryImage;
const previewVideoSrc = createPreviewVideoSrc(review.data.previewVideo);
const hasPreviewGallery = previewImages.length > 0;
const currentReviewPath = `/reviews/${review.slug}/`;
const currentCategory = standardReviewCategories.find((category) => matchesReviewCategory(review.data, category));
const currentSubCategories = getReviewSubCategorCategories(review.data);
const awardTags = getSortedOtherTags(review.data.otherTag);
const currentYear = new Date().getFullYear();
const relatedReviews = getRelatedReviewWorkSlugs(workPath)
	.map((relatedWorkSlug) => latestReviewByWork.get(relatedWorkSlug))
	.filter((entry): entry is CollectionEntry<'reviews'> => Boolean(entry))
	.map((entry) => {
		const relatedLatestReview = latestReviewByWork.get(getWorkPath(entry.slug));

		return {
			...entry.data,
			href: `/reviews/${entry.slug}/`,
			isOutdated: Boolean(relatedLatestReview && relatedLatestReview.slug !== entry.slug),
		};
	});
const relatedReviewsByClass = Array.from(
	relatedReviews.reduce<Map<string, typeof relatedReviews>>((groups, relatedReview) => {
		const group = groups.get(relatedReview.proClass) ?? [];

		group.push(relatedReview);
		groups.set(relatedReview.proClass, group);

		return groups;
	}, new Map()),
).map(([proClass, items]) => ({ proClass, items }));
---

<Layout webTitle={`MOEGN - ${review.data.title}`}>
	<main>
		<nav class="detail-breadcrumb" aria-label="当前位置">
			<a href="/reviews/">评测列表</a>
			<span>/</span>
			{currentCategory ? (
				<>
					<a href={getReviewCategoryHref(currentCategory.slug)}>{currentCategory.title}</a>
					<span>/</span>
				</>
			) : null}
			<span>{review.data.title}</span>
		</nav>

		<section class="detail-hero">
			<div class="detail-cover">
				<img src={review.data.imgSrc} alt={`${review.data.title} 封面`} />
			</div>

			<div class="detail-title">
				<p class="detail-kicker">MOEGN 评测</p>
				<h1>{review.data.title}</h1>
				<p class="detail-subtitle">{review.data.subTitle}</p>

				<div class="detail-meta" aria-label="评测信息">
					{awardTags.map((tag) => (
						<b class:list={['detail-award-tag', `is-${tag.tone}`]}>{tag.label}</b>
					))}
					<span>{review.data.proClass}</span>
					{currentSubCategories.map((category) => (
						<a href={getReviewCategoryHref(category.slug)}>
							{category.title}
							<span class="detail-meta-icon" aria-hidden="true"><W3SvgIcon name="external" /></span>
						</a>
					))}
					<span>{review.data.reviewType}</span>
					<span>{publishedDate}</span>
					<span>{review.data.scoreTag}</span>
				</div>

				<p class="detail-summary">{review.data.summary}</p>

				<div class="detail-actions">
					{review.data.blogHref ? <a class="detail-action is-solid" href={review.data.blogHref} target="_blank" rel="noreferrer">阅读原文</a> : null}
					<div class="detail-link-menu" data-third-party-menu>
						<button class="detail-action is-outline" type="button" aria-expanded="false" data-third-party-menu-button>
							<span>作品资料</span>
							<span class="detail-action-icon" aria-hidden="true"><W3SvgIcon name="chevron-down" /></span>
						</button>
						<div class="detail-link-menu-list" aria-hidden="true" data-third-party-menu-list inert>
							{review.data.thirdPartyLinks.length ? (
								review.data.thirdPartyLinks.map((link) => (
									<a href={link.href} target="_blank" rel="noreferrer">
										<span>{link.label}</span>
										<span aria-hidden="true"><W3SvgIcon name="external" /></span>
									</a>
								))
							) : (
								<span class="detail-link-empty">暂无第三方链接</span>
							)}
						</div>
					</div>
				</div>
			</div>

			<div class:list={['detail-score', { 'is-outdated': isOutdatedReview }]} aria-label={`评分 ${review.data.score}`}>
				<span>{review.data.score}{isOutdatedReview ? <sup>*</sup> : null}</span>
				<b>{review.data.scoreTag}</b>
				{latestReview && isOutdatedReview ? (
					<small class="score-stale-note">
						该评测已过期，不具有时效性。<a href={`/reviews/${latestReview.slug}/`}>查看最新评测</a>
					</small>
				) : null}
			</div>
		</section>

		<article class="detail-article">
			<div class="article-heading">
				<p>Review Overview</p>
				<h2>评测<br>概览</h2>
			</div>
			<div class="article-body">
				<Content />
			</div>
		</article>

		{review.data.infoSummary.length ? (
			<section class="work-info-summary" aria-label="作品信息总结">
				<div class="work-info-heading">
					<p>Work Info</p>
					<h2>信息<br>总结</h2>
				</div>
				<div class="work-info-body">
					<dl>
						{review.data.infoSummary.map((item) => (
							<div>
								<dt>{item.label}</dt>
								<dd>{item.value}</dd>
							</div>
						))}
					</dl>
				</div>
			</section>
		) : null}

		<section class="detail-preview-section" aria-label="详情预览">
			<div class="detail-section-heading">
				<p>Detail Preview</p>
				<h2>详情<br>预览</h2>
			</div>
			<div class="detail-preview-body">
				<div class="preview-feature">
					{review.data.previewVideo ? (
						<button
							class="preview-image-button preview-video-button is-featured"
							type="button"
							data-preview-video={previewVideoSrc}
							aria-label={`播放 ${review.data.title} 预览视频`}
						>
							<img src={previewVideoCover} alt={`${review.data.title} 视频封面`} />
							{review.data.previewVideoTitle ? (
								<b class="preview-video-title">{review.data.previewVideoTitle}</b>
							) : null}
							<span aria-hidden="true">
								<W3SvgIcon name="play" />
							</span>
						</button>
					) : (
						<button class="preview-image-button is-featured" type="button" data-preview-image={previewPrimaryImage} aria-label={`查看 ${review.data.title} 预览图`}>
							<img src={previewPrimaryImage} alt={`${review.data.title} 预览图`} />
						</button>
					)}
				</div>

				{hasPreviewGallery ? (
					<div class="preview-shot-grid" aria-label="截图预览">
						{previewImages.map((image, index) => (
							<button class="preview-image-button" type="button" data-preview-image={image} aria-label={`查看截图 ${index + 1}`}>
								<img src={image} alt={`${review.data.title} 截图 ${index + 1}`} />
							</button>
						))}
					</div>
				) : null}
			</div>
		</section>

		{relatedReviews.length ? (
			<section class="detail-related-section" aria-label="关联作品">
				<div class="detail-section-heading">
					<p>Related Works</p>
					<h2>关联<br>作品</h2>
				</div>
				<div class="detail-related-body">
					<div class="related-review-groups">
						{relatedReviewsByClass.map((group) => (
							<section class="related-class-group" aria-label={`关联${group.proClass}`}>
								<h3>{group.proClass}</h3>
								<ul role="list" class="related-review-grid">
									{group.items.map((relatedReview) => (
										<li>
											<a class="related-cover-card" href={relatedReview.href} aria-label={`${relatedReview.title} ${relatedReview.reviewType}`}>
												<img src={relatedReview.imgSrc} alt={`${relatedReview.title} 封面`} />
												<span class="related-title">{relatedReview.title}</span>
												<span
													class:list={['related-score', { 'is-outdated': relatedReview.isOutdated }]}
													data-stale-reason={relatedReview.isOutdated ? '该评测已过期，不具有时效性。已有更新的评测。' : undefined}
													aria-label={relatedReview.isOutdated ? `评分 ${relatedReview.score}，该评测已过期，不具有时效性。` : `评分 ${relatedReview.score}`}
												>
													{relatedReview.score}{relatedReview.isOutdated ? <sup>*</sup> : null}
												</span>
											</a>
										</li>
									))}
								</ul>
							</section>
						))}
					</div>
				</div>
			</section>
		) : null}

		<section
			class="detail-share-section"
			aria-label={`分享${review.data.proClass}`}
			data-share-section
			data-share-title={review.data.title}
			data-share-subtitle={review.data.subTitle}
			data-share-score={review.data.score}
			data-share-score-tag={review.data.scoreTag}
			data-share-class={review.data.proClass}
			data-share-summary={review.data.summary}
			data-share-image={review.data.imgSrc}
			data-share-path={currentReviewPath}
		>
			<div class="detail-section-heading">
				<p>Share Review</p>
				<h2>分享<br>{review.data.proClass}</h2>
			</div>
			<div class="detail-share-body">
				<div class="share-entry-panel">
					<ul class="share-entry-card-list">
						<Card
							href={currentReviewPath}
							proClass={review.data.proClass}
							title={review.data.title}
							subTitle={review.data.subTitle}
							score={review.data.score}
							scoreTag={review.data.scoreTag}
							body="生成一张适合保存与转发的图像分享卡片，扫描卡片中的二维码即可访问本页。"
							imgSrc={review.data.imgSrc}
							awardTags={awardTags}
							buttonText="点击分享"
							buttonAction="share-preview"
						/>
					</ul>
				</div>
				<div class="share-entry-actions" aria-label="其他分享方式">
					<button type="button" data-share-copy-link title="复制本页链接" aria-label="复制本页链接">
						<W3SvgIcon name="copy" />
					</button>
					<button type="button" data-share-native title="系统分享" aria-label="系统分享">
						<W3SvgIcon name="share" />
					</button>
					<a href={currentReviewPath} target="_blank" rel="noreferrer" title="新窗口打开本页" aria-label="新窗口打开本页">
						<W3SvgIcon name="external" />
					</a>
					<!--<span class="share-entry-feedback" data-share-feedback aria-live="polite"></span> -->
				</div>
				<dialog class="share-preview-dialog" data-share-dialog aria-label={`${review.data.title} 分享卡片预览`}>
					<div class="share-dialog-toolbar">
						<p data-share-status>调整预览后可生成分享图片</p>
						<div class="share-dialog-controls" aria-label="预览操作">
							<button type="button" data-share-zoom-out aria-label="缩小预览">-</button>
							<button type="button" data-share-zoom-reset>100%</button>
							<button type="button" data-share-zoom-in aria-label="放大预览">+</button>
							<button class="share-generate-button" type="button" data-share-generate data-share-filename={`${review.slug.replaceAll('/', '-')}-share.png`}>生成并下载</button>
							<button type="button" data-share-close aria-label="关闭分享预览">×</button>
						</div>
					</div>
					<div class="share-preview-viewport">
						<div class="share-preview-scale" data-share-scale>
							<div class="share-card-export" data-share-export aria-label={`${review.data.title} 分享卡片`}>
								{moeqyGirlImages.length ? (
									<img
										class="share-card-mascot"
										src={moeqyGirlImages[0]}
										data-share-mascot
										data-share-mascots={JSON.stringify(moeqyGirlImages)}
										alt=""
										aria-hidden="true"
									/>
								) : null}
								<ul class="share-card-list">
									<Card
										href={currentReviewPath}
										proClass={review.data.proClass}
										title={review.data.title}
										subTitle={review.data.subTitle}
										score={review.data.score}
										scoreTag={review.data.scoreTag}
										body={review.data.summary}
										imgSrc={review.data.imgSrc}
										awardTags={awardTags}
										buttonText=""
									/>
								</ul>
								{isOutdatedReview ? (
									<div class="share-card-stale-note">
										<span>时效提醒</span>
										<p>该评测已过期，不具有时效性，请以最新评测为准。</p>
									</div>
								) : null}
								<div class="share-card-footer">
									<h3 style="padding: 0; margin: 0;">扫描二维码阅读详情</h3>
									<img data-share-qr alt={`${review.data.title} 二维码`} />
									<p>Copyright © {currentYear} MOEGN. Some rights reserved.</p>
								</div>
							</div>
						</div>
					</div>
				</dialog>
			</div>
		</section>

		<dialog class="image-lightbox" data-image-lightbox>
			<button class="image-lightbox-close" type="button" data-image-lightbox-close aria-label="关闭图片预览">×</button>
			<img src={previewPrimaryImage} alt="截图详情" data-image-lightbox-img />
		</dialog>

		<dialog class="video-lightbox" data-video-lightbox>
			<button class="image-lightbox-close" type="button" data-video-lightbox-close aria-label="关闭视频预览">×</button>
			<iframe
				title={`${review.data.title} 预览视频`}
				loading="lazy"
				allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
				allowfullscreen
				data-video-lightbox-frame
			></iframe>
		</dialog>
	</main>
</Layout>

<style>
	main {
		--section-title-offset: 36px;
		width: min(1500px, 100%);
		margin: 0 auto;
		padding: 104px 20px 76px;
		color: var(--text-color);
	}

	.detail-breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
		margin-bottom: 18px;
		color: var(--grey-5);
		font-size: 14px;
		font-family: var(--font-light);
	}

	.detail-breadcrumb a {
		color: var(--color-main);
		text-decoration: none;
	}

	.detail-breadcrumb a:hover,
	.detail-breadcrumb a:focus-visible {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.detail-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(220px, 360px) minmax(0, 1fr);
		gap: clamp(26px, 5vw, 72px);
		align-items: flex-start;
		min-height: 560px;
		padding: clamp(28px, 5vw, 68px);
		overflow: visible;
		border-radius: 10px;
		background:
			linear-gradient(120deg, var(--color-main) 0, var(--color-light) 100%),
			var(--color-main);
		box-shadow: 0 18px 40px rgba(255, 105, 180, .22);
	}

	.detail-cover,
	.detail-title,
	.detail-score {
		position: relative;
		z-index: 1;
	}

	.detail-cover {
		width: min(100%, 340px);
		margin-inline: auto;
		overflow: hidden;
		border-radius: 10px;
		box-shadow: 0 18px 38px rgba(98, 38, 62, .24);
		background: var(--grey-0);
	}

	.detail-cover img {
		display: block;
		width: 100%;
		aspect-ratio: 3 / 4;
		object-fit: cover;
	}

	.detail-title {
		max-width: 820px;
		color: var(--grey-0);
	}

	.detail-kicker {
		margin: 0 0 12px;
		font-size: 14px;
		font-family: var(--font-light);
		letter-spacing: 2px;
	}

	.detail-title h1 {
		margin: 0;
		font-size: clamp(3.2rem, 7vw, 6rem);
		font-family: var(--font-heavy);
		line-height: .94;
		letter-spacing: -5px;
	}

	.detail-subtitle {
		margin: 14px 0 0;
		color: rgba(255, 255, 255, .78);
		font-size: clamp(1rem, 2vw, 1.45rem);
		font-family: var(--font-light);
		text-transform: uppercase;
	}

	.detail-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 28px;
	}

	.detail-meta > span,
	.detail-meta > a {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		min-height: 34px;
		padding: 0 14px;
		border: 1px solid rgba(255, 255, 255, .48);
		border-radius: 999px;
		background: rgba(255, 255, 255, .13);
		color: var(--grey-0);
		font-size: 14px;
		font-family: var(--font-medium);
		text-decoration: none;
	}

	.detail-meta a:hover,
	.detail-meta a:focus-visible {
		background: rgba(255, 255, 255, .24);
	}

	.detail-meta-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 14px;
		height: 14px;
		flex: 0 0 auto;
	}

	.detail-award-tag {
		--award-glow: rgba(255, 207, 82, .82);
		display: inline-flex;
		align-items: center;
		min-height: 34px;
		padding: 0 14px;
		border-radius: 999px;
		background: linear-gradient(135deg, #f7b733, #ffd977);
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, .22) inset,
			0 0 14px var(--award-glow),
			0 0 28px var(--award-glow);
		color: var(--grey-0);
		font-size: 14px;
		font-family: var(--font-heavy);
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.detail-award-tag.is-silver {
		--award-glow: rgba(214, 225, 234, .86);
		background: linear-gradient(135deg, #8fa5ba, #d6e1ea);
	}

	.detail-award-tag.is-bronze {
		--award-glow: rgba(227, 161, 95, .84);
		background: linear-gradient(135deg, #b86b2c, #e3a15f);
	}

	.detail-summary {
		max-width: 760px;
		margin: 26px 0 0;
		font-size: clamp(1rem, 1.7vw, 1.2rem);
		line-height: 1.8;
	}

	.detail-actions {
		position: relative;
		z-index: 4;
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.detail-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 46px;
		padding: 0 24px;
		border: 1px solid var(--grey-0);
		border-radius: 999px;
		cursor: pointer;
		font-size: 15px;
		font-family: var(--font-medium);
		text-decoration: none;
		transition: transform .2s ease-in-out, background .2s ease-in-out, color .2s ease-in-out;
	}

	.detail-action:hover,
	.detail-action:focus-visible {
		transform: translateY(-2px);
	}

	.detail-action.is-solid {
