---
import Layout from '../../../layouts/Layout.astro';
import CategoryReviewSections from '../../../components/CategoryReviewSections.astro';
import { reviewCategories, type ReviewCategory } from '../../../data/reviewCategories';
import { getCategoryReviews } from '../../../lib/reviewCategory';

export function getStaticPaths() {
	return reviewCategories.map((category) => ({
		params: { slug: category.slug },
		props: { category },
	}));
}

const { category } = Astro.props as { category: ReviewCategory };
const reviews = await getCategoryReviews(category);
---

<Layout webTitle={`MOEGN - ${category.title}`}>
	<main>
		<nav class="category-breadcrumb" aria-label="当前位置">
			<a href="/reviews/">评测列表</a>
			<span>/</span>
			<span>{category.title}</span>
		</nav>

		<CategoryReviewSections category={category} reviews={reviews} />
	</main>
</Layout>

<style>
	main {
		width: min(1500px, 100%);
		margin: 0 auto;
		padding: 104px 20px 70px;
		color: var(--text-color);
	}

	.category-breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
		margin-bottom: 18px;
		color: var(--grey-5);
		font-size: 14px;
		font-family: var(--font-light);
	}

	.category-breadcrumb a {
		color: var(--color-main);
		text-decoration: none;
	}

	.category-breadcrumb a:hover,
	.category-breadcrumb a:focus-visible {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	@media only screen and (max-width: 720px) {
		main {
			padding-top: 90px;
			padding-inline: 12px;
		}
	}
</style>
