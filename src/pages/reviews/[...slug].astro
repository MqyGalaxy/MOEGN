</style>

<script>
	import { exportDomToPng } from '../../scripts/exportDomToPng';
	import QRCode from 'qrcode';

	document.querySelectorAll<HTMLElement>('[data-third-party-menu]').forEach((menu) => {
		const button = menu.querySelector<HTMLButtonElement>('[data-third-party-menu-button]');
		const list = menu.querySelector<HTMLElement>('[data-third-party-menu-list]');

		if (!button || !list) return;

		const setMenuOpen = (isOpen: boolean) => {
			menu.classList.toggle('is-open', isOpen);
			button.setAttribute('aria-expanded', String(isOpen));
			list.setAttribute('aria-hidden', String(!isOpen));

			if (isOpen) {
				list.removeAttribute('inert');
			} else {
				list.setAttribute('inert', '');
			}
		};

		button.addEventListener('click', () => {
			setMenuOpen(!menu.classList.contains('is-open'));
		});

		document.addEventListener('click', (event) => {
			if (!menu.contains(event.target as Node)) {
				setMenuOpen(false);
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				setMenuOpen(false);
			}
		});
	});

	const imageLightbox = document.querySelector<HTMLDialogElement>('[data-image-lightbox]');
	const lightboxImage = document.querySelector<HTMLImageElement>('[data-image-lightbox-img]');
	const lightboxClose = document.querySelector<HTMLButtonElement>('[data-image-lightbox-close]');
	const previewButtons = document.querySelectorAll<HTMLButtonElement>('[data-preview-image]');
	const videoLightbox = document.querySelector<HTMLDialogElement>('[data-video-lightbox]');
	const videoFrame = document.querySelector<HTMLIFrameElement>('[data-video-lightbox-frame]');
	const videoClose = document.querySelector<HTMLButtonElement>('[data-video-lightbox-close]');
	const videoButtons = document.querySelectorAll<HTMLButtonElement>('[data-preview-video]');

	previewButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const image = button.dataset.previewImage;

			if (!image || !imageLightbox || !lightboxImage) return;

			lightboxImage.src = image;
			imageLightbox.showModal();
		});
	});

	lightboxClose?.addEventListener('click', () => imageLightbox?.close());
	imageLightbox?.addEventListener('click', (event) => {
		if (event.target === imageLightbox) {
			imageLightbox.close();
		}
	});

	const closeVideo = () => {
		if (videoFrame) {
			videoFrame.removeAttribute('src');
		}

		videoLightbox?.close();
	};

	videoButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const video = button.dataset.previewVideo;

			if (!video || !videoLightbox || !videoFrame) return;

			videoFrame.src = video;
			videoLightbox.showModal();
		});
	});

	videoClose?.addEventListener('click', closeVideo);
	videoLightbox?.addEventListener('click', (event) => {
		if (event.target === videoLightbox) {
			closeVideo();
		}
	});
	videoLightbox?.addEventListener('close', () => videoFrame?.removeAttribute('src'));

	const waitForExportImage = (image: HTMLImageElement) => new Promise<void>((resolve) => {
		if (image.complete) {
			resolve();
			return;
		}

		image.addEventListener('load', () => resolve(), { once: true });
		image.addEventListener('error', () => resolve(), { once: true });
	});

	document.querySelectorAll<HTMLElement>('[data-share-section]').forEach((section) => {
		const exportElement = section.querySelector<HTMLElement>('[data-share-export]');
		const dialog = section.querySelector<HTMLDialogElement>('[data-share-dialog]');
		const openButton = section.querySelector<HTMLButtonElement>('[data-card-action="share-preview"]');
		const closeButton = section.querySelector<HTMLButtonElement>('[data-share-close]');
		const generateButton = section.querySelector<HTMLButtonElement>('[data-share-generate]');
		const status = section.querySelector<HTMLElement>('[data-share-status]');
		const qrImage = section.querySelector<HTMLImageElement>('[data-share-qr]');
		const scaleElement = section.querySelector<HTMLElement>('[data-share-scale]');
		const zoomOutButton = section.querySelector<HTMLButtonElement>('[data-share-zoom-out]');
		const zoomResetButton = section.querySelector<HTMLButtonElement>('[data-share-zoom-reset]');
		const zoomInButton = section.querySelector<HTMLButtonElement>('[data-share-zoom-in]');
		const copyLinkButton = section.querySelector<HTMLButtonElement>('[data-share-copy-link]');
		const nativeShareButton = section.querySelector<HTMLButtonElement>('[data-share-native]');
		const shareFeedback = section.querySelector<HTMLElement>('[data-share-feedback]');
		const shareMascot = section.querySelector<HTMLImageElement>('[data-share-mascot]');

		if (!exportElement || !dialog || !openButton || !closeButton || !generateButton || !status || !qrImage || !scaleElement || !zoomOutButton || !zoomResetButton || !zoomInButton) return;

		const pageUrl = new URL(section.dataset.sharePath ?? location.pathname, location.origin).href;
		const downloadFileName = generateButton.dataset.shareFilename || 'moegn-review-share.png';
		const defaultGenerateText = generateButton.textContent || '生成并下载';
		let previewScale = 1;
		let feedbackTimer = 0;
		let currentMascotIndex = -1;

		const updatePreviewScale = () => {
			const width = exportElement.offsetWidth || 640;
			const height = exportElement.offsetHeight || exportElement.scrollHeight || 1024;

			scaleElement.style.transform = `scale(${previewScale})`;
			scaleElement.style.width = `${width * previewScale}px`;
			scaleElement.style.height = `${(height - 26) * previewScale}px`;
			zoomResetButton.textContent = `${Math.round(previewScale * 100)}%`;
		};
		const fitPreviewToViewport = () => {
			if (!window.matchMedia('(max-width: 560px)').matches) {
				previewScale = 1;
				updatePreviewScale();
				return;
			}

			const viewportWidth = dialog.clientWidth || window.innerWidth;
			const availableWidth = Math.max(240, viewportWidth - 24);
			const fittedScale = Math.floor(Math.min(1, availableWidth / (exportElement.offsetWidth || 640)) * 100) / 100;
			previewScale = Math.max(.4, fittedScale);
			updatePreviewScale();
		};
		const renderQr = async () => {
			qrImage.src = await QRCode.toDataURL(pageUrl, {
				width: 240,
				margin: 1,
				color: {
					dark: '#ffffff',
					light: '#00000000',
				},
			});
		};
		const randomizeShareMascot = () => {
			if (!shareMascot?.dataset.shareMascots) return;

			try {
				const mascotImages = JSON.parse(shareMascot.dataset.shareMascots) as string[];

				if (!mascotImages.length) return;

				let nextIndex = Math.floor(Math.random() * mascotImages.length);

				if (mascotImages.length > 1 && nextIndex === currentMascotIndex) {
					nextIndex = (nextIndex + 1) % mascotImages.length;
				}

				currentMascotIndex = nextIndex;
				shareMascot.src = mascotImages[nextIndex];
			} catch {
				// Keep the default mascot if the data attribute cannot be parsed.
			}
		};
		const exportDomShareCard = async () => {
			await renderQr();
			await document.fonts?.ready;
			await Promise.all(Array.from(exportElement.querySelectorAll<HTMLImageElement>('img')).map(waitForExportImage));
			await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

			const width = exportElement.offsetWidth || 640;
			const height = Math.ceil(exportElement.scrollHeight || exportElement.offsetHeight || 1024);
			const blob = await exportDomToPng(exportElement, {
				backgroundColor: '#00000000',
				height,
				pixelRatio: 2,
				skipAutoScale: true,
				style: {
					height: `${height - 26}px`,
					transform: 'none',
					width: `${width}px`,
				},
				width,
			});

			if (!blob) {
				throw new Error('DOM export failed');
			}

			return blob;
		};
		const downloadBlob = (blob: Blob) => {
			const url = URL.createObjectURL(blob);
			const link = document.createElement('a');

			link.href = url;
			link.download = downloadFileName;
			link.style.display = 'none';
			document.body.appendChild(link);
			link.click();
			link.remove();
			window.setTimeout(() => URL.revokeObjectURL(url), 1000);
		};
		const showShareFeedback = (message: string) => {
			if (!shareFeedback) return;

			window.clearTimeout(feedbackTimer);
			shareFeedback.textContent = message;
			feedbackTimer = window.setTimeout(() => {
				shareFeedback.textContent = '';
			}, 1800);
		};
		const copyPageUrl = async () => {
			try {
				if (!navigator.clipboard) {
					throw new Error('Clipboard API is unavailable');
				}

				await navigator.clipboard.writeText(pageUrl);
				showShareFeedback('已复制');
			} catch {
				showShareFeedback('复制失败');
			}
		};

		renderQr();
		updatePreviewScale();

		if (!navigator.share && nativeShareButton) {
			nativeShareButton.hidden = true;
		}

		copyLinkButton?.addEventListener('click', copyPageUrl);
		nativeShareButton?.addEventListener('click', async () => {
			if (!navigator.share) return;

			try {
				await navigator.share({
					title: document.title,
					url: pageUrl,
				});
			} catch {
				showShareFeedback('已取消');
			}
		});

		openButton.addEventListener('click', async () => {
			randomizeShareMascot();
			await renderQr();
			dialog.showModal();
			fitPreviewToViewport();
		});

		closeButton.addEventListener('click', () => dialog.close());
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) {
				dialog.close();
			}
		});

		zoomOutButton.addEventListener('click', () => {
			previewScale = Math.max(.4, Math.round((previewScale - .1) * 10) / 10);
			updatePreviewScale();
		});

		zoomResetButton.addEventListener('click', () => {
			previewScale = 1;
			updatePreviewScale();
		});

		zoomInButton.addEventListener('click', () => {
			previewScale = Math.min(2, Math.round((previewScale + .1) * 10) / 10);
			updatePreviewScale();
		});

		generateButton.addEventListener('click', async () => {
			generateButton.disabled = true;
			generateButton.textContent = '正在生成...';
			status.textContent = '正在生成分享图片...';

			try {
				const blob = await exportDomShareCard();

				downloadBlob(blob);
				status.textContent = '分享图片已下载';
			} catch (error) {
				console.error('MOEGN share DOM export failed', error);
				status.textContent = 'DOM 导出失败，请检查封面图片是否支持跨域或改用本地图片';
			} finally {
				generateButton.disabled = false;
				generateButton.textContent = defaultGenerateText;
			}
		});
	});
</script>
