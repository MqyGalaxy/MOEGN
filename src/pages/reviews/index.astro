<script>
	const recommendationCards = Array.from(document.querySelectorAll<HTMLElement>('[data-recommendation-card]'));

	if (recommendationCards.length) {
		const refreshDuration = 10000;
		const transitionDuration = 320;
		let activeIndex = Math.floor(Math.random() * recommendationCards.length);
		let startedAt = performance.now();
		let paused = false;
		let isSwitching = false;
		let animationFrame = 0;

		const getNextIndex = () => {
			if (recommendationCards.length < 2) return activeIndex;

			let nextIndex = activeIndex;

			while (nextIndex === activeIndex) {
				nextIndex = Math.floor(Math.random() * recommendationCards.length);
			}

			return nextIndex;
		};

		const updateTimer = (elapsed = 0) => {
			const activeCard = recommendationCards[activeIndex];
			const progress = Math.min(elapsed / refreshDuration, 1);
			const countdown = Math.max(Math.ceil((refreshDuration - elapsed) / 1000), 0);

			activeCard.style.setProperty('--timer-progress', String(progress));
			activeCard.querySelector('[data-recommendation-countdown]')?.replaceChildren(String(countdown));
			activeCard.querySelector('[data-recommendation-timer]')?.setAttribute(
				'aria-label',
				`随机推荐将在 ${countdown} 秒后刷新`,
			);
		};

		const resetCardTimer = (card: HTMLElement) => {
			card.style.setProperty('--timer-progress', '0');
			card.querySelector('[data-recommendation-countdown]')?.replaceChildren('10');
		};

		const showCard = (nextIndex: number, animate = false) => {
			if (isSwitching) return;

			if (recommendationCards.length < 2 || nextIndex === activeIndex) {
				startedAt = performance.now();
				updateTimer(0);
				return;
			}

			const previousCard = recommendationCards[activeIndex];
			const nextCard = recommendationCards[nextIndex];

			if (animate && previousCard) {
				isSwitching = true;
				previousCard.classList.add('is-leaving');

				window.setTimeout(() => {
					previousCard.hidden = true;
					previousCard.classList.remove('is-active', 'is-leaving');

					activeIndex = nextIndex;
					startedAt = performance.now();

					nextCard.hidden = false;
					nextCard.classList.add('is-active', 'is-entering');
					resetCardTimer(nextCard);

					requestAnimationFrame(() => {
						nextCard.classList.remove('is-entering');
					});

					window.setTimeout(() => {
						isSwitching = false;
					}, transitionDuration);
				}, transitionDuration);

				return;
			}

			activeIndex = nextIndex;
			startedAt = performance.now();

			recommendationCards.forEach((card, index) => {
				const isActive = index === activeIndex;

				card.hidden = !isActive;
				card.classList.toggle('is-active', isActive);
				card.classList.remove('is-entering', 'is-leaving');
				resetCardTimer(card);
			});
		};

		const resetTimer = () => {
			startedAt = performance.now();
			updateTimer(0);
		};

		const tick = (now: number) => {
			if (!paused && !isSwitching) {
				const elapsed = now - startedAt;

				if (elapsed >= refreshDuration) {
					showCard(getNextIndex(), true);
				} else {
					updateTimer(elapsed);
				}
			}

			animationFrame = requestAnimationFrame(tick);
		};

		recommendationCards.forEach((card) => {
			const nextControls = card.querySelectorAll<HTMLElement>('[data-recommendation-next]');

			nextControls.forEach((control) => {
				control.addEventListener('click', () => {
					if (card.hidden || isSwitching) return;

					showCard(getNextIndex(), true);
				});
			});

			card.addEventListener('mouseenter', () => {
				if (card.hidden) return;

				paused = true;
			});

			card.addEventListener('mouseleave', () => {
				if (card.hidden) return;

				paused = false;
				resetTimer();
			});
		});

		const initialIndex = activeIndex;
		activeIndex = -1;
		showCard(initialIndex);
		animationFrame = requestAnimationFrame(tick);

		document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animationFrame), { once: true });
	}
</script>
