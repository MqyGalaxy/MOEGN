---
import Layout from '../../layouts/Layout.astro';
import W3SvgIcon from '../../components/W3SvgIcon.astro';
---

<Layout webTitle="MOEGN - 卡片编辑器">
	<main>
		<section class="editor-shell" data-card-editor>
			<aside class="editor-panel" aria-label="卡片设置">
				<div class="panel-block">
					<p>Card Editor</p>
					<h1>卡片编辑器</h1>
				</div>

				<div class="panel-block" data-panel-default-open>
					<h2><span>风格</span><span class="panel-heading-icon"><W3SvgIcon name="chevron-down" /></span></h2>
					<div class="segmented-control" role="group" aria-label="卡片风格">
						<button type="button" data-style-option="classic" class="is-active">经典</button>
						<button type="button" data-style-option="detail">信息栏</button>
					</div>
					<div class="segmented-control" role="group" aria-label="卡片尺寸">
						<button type="button" data-size-option="large" class="is-active">大卡片</button>
						<button type="button" data-size-option="small">小卡片</button>
					</div>
				</div>

				<div class="panel-block">
					<h2><span>配色</span><span class="panel-heading-icon"><W3SvgIcon name="chevron-down" /></span></h2>
					<div class="palette-grid">
						<button type="button" data-palette="#ff69b4,#ffb6c1,#ffffff,#ffffff,#333333" style="--swatch-a:#ff69b4;--swatch-b:#ffb6c1;">萌趣粉</button>
						<button type="button" data-palette="#4c8df6,#8fc5ff,#ffffff,#ffffff,#26364d" style="--swatch-a:#4c8df6;--swatch-b:#8fc5ff;">聪明蓝</button>
						<button type="button" data-palette="#36b37e,#8de0aa,#ffffff,#ffffff,#23382e" style="--swatch-a:#36b37e;--swatch-b:#8de0aa;">早苗绿</button>
						<button type="button" data-palette="#8965e8,#c088ff,#ffffff,#ffffff,#33254d" style="--swatch-a:#8965e8;--swatch-b:#c088ff;">基佬紫</button>
					</div>
					<label>
						<span>主色</span>
						<input type="color" value="#ff69b4" data-color-input="accent" />
					</label>
					<label>
						<span>辅色</span>
						<input type="color" value="#ffb6c1" data-color-input="accent2" />
					</label>
					<label>
						<span>背景文字</span>
						<input type="color" value="#ffffff" data-color-input="paperText" />
					</label>
					<label>
						<span>卡片底色</span>
						<input type="color" value="#ffffff" data-color-input="cardBg" />
					</label>
					<label>
						<span>卡片文字</span>
						<input type="color" value="#333333" data-color-input="cardText" />
					</label>
				</div>

				<div class="panel-block">
					<h2><span>封面</span><span class="panel-heading-icon"><W3SvgIcon name="chevron-down" /></span></h2>
					<label>
						<span>图片 URL</span>
						<input type="url" value="https://lain.bgm.tv/r/400/pic/cover/l/96/d1/424663_mM5GN.jpg" data-cover-input />
					</label>
					<button class="panel-action" type="button" data-cover-apply>应用封面</button>
				</div>

				<div class="panel-block" data-large-award-controls>
					<h2><span>奖项</span><span class="panel-heading-icon"><W3SvgIcon name="chevron-down" /></span></h2>
					<label class="checkbox-line">
						<span>显示奖项</span>
						<input type="checkbox" checked data-large-awards-toggle />
					</label>
					<div class="award-editor-list" data-large-award-list>
						<div class="award-editor-item" data-large-award-item>
							<input type="text" value="工具栏编辑奖项" aria-label="奖项文本" data-large-award-text />
							<select aria-label="奖项等级" data-large-award-tone>
								<option value="gold">金奖</option>
								<option value="silver">银奖</option>
								<option value="bronze">铜奖</option>
							</select>
							<button type="button" aria-label="删除奖项" data-large-award-delete>×</button>
						</div>
					</div>
					<button class="award-add-button" type="button" aria-label="添加奖项" data-large-award-add>+</button>
					<p class="panel-note">每个奖项会同步生成到经典大卡片封面左下角。</p>
				</div>

				<div class="panel-block export-panel" data-export-panel>
					<h2>导出</h2>
					<button class="export-button" type="button" data-export-button>生成预览</button>
					<p class="export-status" data-export-status>点击画布中的文字即可编辑，当前导出画布尺寸固定。</p>
				</div>
			</aside>

			<button class="mobile-panel-backdrop" type="button" data-panel-backdrop aria-label="关闭工具栏"></button>

			<section class="workspace" aria-label="卡片画布">
				<div class="workspace-toolbar">
					<div>
						<strong data-current-mode>经典 / 大卡片</strong>
						<span>预览使用站内组件与详情页相同的 HTML 结构和样式</span>
					</div>
					<div class="workspace-actions">
						<button class="panel-toggle" type="button" data-panel-toggle aria-expanded="false" aria-label="打开工具栏">
							<span class="panel-toggle-icon"><W3SvgIcon name="tool" /></span>
							<span class="panel-toggle-text">工具栏</span>
						</button>
						<a href="/generator/">生成器主页</a>
					</div>
				</div>

				<div class="stage-scroll">
					<div class="export-stage" data-export-stage data-style="classic" data-size="large" data-variant="classic-large">
						<div class="stage-decoration stage-0"></div>
						<div class="stage-decoration stage-1"></div>

						<ul class="card-preview classic-large-card" data-preview="classic-large" aria-label="经典大卡片">
							<li class="moegn">
								<div class="pro-img">
									<div class="pro-img-body">
										<img data-cover-image alt="img" src="https://lain.bgm.tv/r/400/pic/cover/l/96/d1/424663_mM5GN.jpg" />
										<div class="pro-cover-awards" aria-label="评测标签" data-large-awards>
											<b class="pro-cover-award is-gold" data-generated-award>工具栏编辑奖项</b>
										</div>
									</div>
								</div>
								<div class="pro-page">
									<div class="pro-title">
										<div class="pro-score"><span contenteditable="true" data-edit-field="score">8</span></div>
										<div class="pro-title-text">
											<div class="title">
												<div class="pro-class" contenteditable="true" data-edit-field="proClass">番剧</div>
												<span title="憧憬成为魔法少女" contenteditable="true" data-edit-field="title">憧憬成为魔法少女</span>
												<b contenteditable="true" data-edit-field="subTitle">魔法少女にあこがれて</b>
											</div>
											<div class="pro-score-tag" style="--score-tag-chars: 2;" contenteditable="true" data-edit-field="scoreTag">佳作</div>
										</div>
									</div>
									<div class="pro-text">
										<div class="pro-author" contenteditable="true" data-edit-field="reviewSource">MOEGN 评测</div>
										<p contenteditable="true" data-edit-field="summary">自从《魔法少女小圆》这样的代表性作品诞生后，以魔法少女为题材的作品大多都离不开“致郁”“黑深残”的标签。本作却开辟了一条新的路，把搞笑、反套路和角色关系放在了更靠前的位置。</p>
									</div>
								</div>
							</li>
						</ul>

						<ul class="card-preview classic-small-card" data-preview="classic-small" aria-label="经典小卡片">
							<li class="moegn">
								<div class="pro-img">
									<div class="pro-img-body">
										<img data-cover-image alt="img" src="https://lain.bgm.tv/r/400/pic/cover/l/96/d1/424663_mM5GN.jpg" />
									</div>
								</div>
								<div class="pro-page">
									<div class="pro-title">
										<div class="pro-score"><span contenteditable="true" data-edit-field="score">8</span></div>
										<div class="pro-title-text">
											<div class="title">
												<div class="pro-class" contenteditable="true" data-edit-field="proClass">番剧</div>
												<span title="憧憬成为魔法少女" contenteditable="true" data-edit-field="title">憧憬成为魔法少女</span>
												<b contenteditable="true" data-edit-field="subTitle">魔法少女にあこがれて</b>
											</div>
											<div class="pro-score-tag" contenteditable="true" data-edit-field="scoreTag">佳作</div>
										</div>
									</div>
									<div class="pro-awards" aria-label="评测标签" data-small-awards>
										<b class="pro-award is-gold" data-generated-award>工具栏编辑奖项</b>
									</div>
									<div class="pro-text">
										<div class="pro-author" contenteditable="true" data-edit-field="reviewSource">MOEGN 评测</div>
										<p contenteditable="true" data-edit-field="summary">自从《魔法少女小圆》这样的代表性作品诞生后，以魔法少女为题材的作品大多都离不开“致郁”“黑深残”的标签。本作却开辟了一条新的路，把搞笑、反套路和角色关系放在了更靠前的位置。</p>
									</div>
								</div>
							</li>
						</ul>

						<section class="card-preview detail-hero detail-large-card" data-preview="detail-large" aria-label="信息栏大卡片">
							<div class="detail-cover">
								<img data-cover-image src="https://lain.bgm.tv/r/400/pic/cover/l/96/d1/424663_mM5GN.jpg" alt="卡片封面" />
							</div>

							<div class="detail-title">
								<p class="detail-kicker" contenteditable="true" data-edit-field="reviewSource">MOEGN 评测</p>
								<h1 contenteditable="true" data-edit-field="title">憧憬成为魔法少女</h1>
								<p class="detail-subtitle" contenteditable="true" data-edit-field="subTitle">魔法少女にあこがれて</p>

								<div class="detail-meta" aria-label="评测信息" data-detail-awards>
									<b class="detail-award-tag is-gold" data-generated-award>工具栏编辑奖项</b>
									<button class="detail-tag-add" type="button" aria-label="添加标签" data-detail-tag-add>+</button>
								</div>

								<p class="detail-summary" contenteditable="true" data-edit-field="summary">自从《魔法少女小圆》这样的代表性作品诞生后，以魔法少女为题材的作品大多都离不开“致郁”“黑深残”的标签。本作却开辟了一条新的路，把搞笑、反套路和角色关系放在了更靠前的位置。</p>

								<div class="detail-actions">
								</div>
							</div>

							<div class="detail-score" aria-label="评分">
								<span contenteditable="true" data-edit-field="score">8</span>
								<b contenteditable="true" data-edit-field="scoreTag">佳作</b>
							</div>
						</section>

						<section class="card-preview detail-hero detail-small-card" data-preview="detail-small" aria-label="信息栏小卡片">
							<div class="detail-cover">
								<img data-cover-image src="https://lain.bgm.tv/r/400/pic/cover/l/96/d1/424663_mM5GN.jpg" alt="卡片封面" />
							</div>

							<div class="detail-title">
								<p class="detail-kicker" contenteditable="true" data-edit-field="reviewSource">MOEGN 评测</p>
								<h1 contenteditable="true" data-edit-field="title">憧憬成为魔法少女</h1>
								<p class="detail-subtitle" contenteditable="true" data-edit-field="subTitle">魔法少女にあこがれて</p>

								<div class="detail-meta" aria-label="评测信息" data-detail-awards>
									<b class="detail-award-tag is-gold" data-generated-award>工具栏编辑奖项</b>
									<button class="detail-tag-add" type="button" aria-label="添加标签" data-detail-tag-add>+</button>
								</div>

								<p class="detail-summary" contenteditable="true" data-edit-field="summary">自从《魔法少女小圆》这样的代表性作品诞生后，以魔法少女为题材的作品大多都离不开“致郁”“黑深残”的标签。本作却开辟了一条新的路，把搞笑、反套路和角色关系放在了更靠前的位置。</p>
								
								<div class="detail-actions">
								</div>
							</div>

							<div class="detail-score" aria-label="评分">
								<span contenteditable="true" data-edit-field="score">8</span>
								<b contenteditable="true" data-edit-field="scoreTag">佳作</b>
							</div>
						</section>

						<footer class="generator-footer">
							<div>
								<strong>Powered by MOEGN</strong>
								<span>Scan QR Code to open the card generator.</span>
							</div>
							<img data-generator-qr alt="MOEGN 生成器二维码" />
						</footer>
					</div>
				</div>
			</section>
		</section>

		<div class="export-preview-modal" data-export-preview-modal hidden>
			<div class="export-preview-dialog" role="dialog" aria-modal="true" aria-label="导出预览">
				<div class="export-preview-toolbar">
					<div>
						<strong>导出预览</strong>
						<span>确认预览无误后，再生成并下载图片。</span>
					</div>
					<div class="export-preview-actions">
						<button class="export-preview-download" type="button" data-preview-download>生成并下载</button>
						<button class="export-preview-close" type="button" aria-label="关闭预览" data-preview-close>×</button>
					</div>
				</div>
				<div class="export-preview-viewport">
					<div class="export-preview-host" data-export-preview-host></div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		box-sizing: border-box;
		width: min(1700px, 100%);
		height: 100svh;
		margin: 0 auto;
		overflow: hidden;
		padding: 88px 16px 16px;
		color: var(--text-color);
	}

	.editor-shell {
		display: grid;
		grid-template-columns: 320px minmax(0, 1fr);
		gap: 18px;
		height: 100%;
		min-height: 0;
	}

	.editor-panel,
	.workspace {
		min-height: 0;
		border: 1px solid rgba(255, 105, 180, .18);
		border-radius: 8px;
		background: rgba(255, 255, 255);
		box-shadow: 0 12px 32px rgba(255, 105, 180, .08);
	}

	.editor-panel {
		display: flex;
		flex-direction: column;
		gap: 20px;
		height: 100%;
		overflow: auto;
		padding: 20px;
	}

	.panel-block {
		display: grid;
		gap: 12px;
	}

	.panel-block[data-collapsible] {
		gap: 0;
		padding-bottom: 12px;
		border-bottom: 1px solid rgba(255, 105, 180, .1);
	}

	.panel-block[data-collapsible] h2 {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		min-height: 34px;
		cursor: pointer;
	}

	.panel-heading-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border: 1px solid var(--color-red-a3);
		border-radius: 50%;
		color: var(--color-main);
		transition: transform .18s ease-in-out;
	}

	.panel-block[data-collapsible].is-collapsed .panel-heading-icon {
		transform: rotate(-90deg);
	}

	.panel-block[data-collapsible] > :not(h2) {
		margin-top: 12px;
	}

	.panel-block[data-collapsible].is-collapsed > :not(h2) {
		display: none;
	}

	.panel-block p:first-child {
		margin: 0;
		color: var(--color-main);
		font-size: 13px;
		font-family: var(--font-light);
		letter-spacing: 2px;
	}

	.panel-block h1,
	.panel-block h2 {
		margin: 0;
		color: var(--grey-7);
		font-family: var(--font-heavy);
		line-height: 1.15;
	}

	.panel-block h1 {
		font-size: 34px;
	}

	.panel-block h2 {
		font-size: 16px;
	}

	.export-panel {
		position: sticky;
		bottom: -20px;
		z-index: 2;
		margin-top: auto;
		margin-right: -20px;
		margin-bottom: -20px;
		margin-left: -20px;
		padding: 16px 20px 20px;
		border-top: 1px solid rgba(255, 105, 180, .12);
		background: linear-gradient(180deg, rgba(255, 255, 255, .9), rgba(255, 255, 255, .98));
		backdrop-filter: blur(10px);
	}

	.segmented-control {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px;
	}

	.segmented-control button,
	.panel-action,
	.export-button {
		min-height: 40px;
		border: 1px solid var(--color-red-a3);
		border-radius: 999px;
		background: var(--grey-0);
		color: var(--color-main);
		font-size: 14px;
		font-family: var(--font-medium);
		cursor: pointer;
	}

	.segmented-control button.is-active,
	.export-button {
		border-color: transparent;
		background: linear-gradient(135deg, var(--color-main), var(--color-light));
		color: var(--grey-0);
	}

	.palette-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 8px;
	}

	.palette-grid button {
		min-height: 48px;
		overflow: hidden;
		border: 0;
		border-radius: 8px;
		background: linear-gradient(135deg, var(--swatch-a), var(--swatch-b));
		color: var(--grey-0);
		font-size: 12px;
		font-family: var(--font-heavy);
		cursor: pointer;
		text-shadow: 0 1px 10px rgba(0, 0, 0, .16);
	}

	label {
		display: grid;
		grid-template-columns: 82px minmax(0, 1fr);
		gap: 10px;
		align-items: center;
		color: var(--grey-6);
		font-size: 13px;
	}

	.checkbox-line input {
		justify-self: start;
		width: 18px;
		height: 18px;
		accent-color: var(--color-main);
	}

	.inline-actions {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px;
	}

	.award-editor-list {
		display: grid;
		gap: 8px;
	}

	.award-editor-item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 72px 34px;
		gap: 8px;
		align-items: center;
		padding: 8px;
		border: 1px solid var(--color-red-a3);
		border-radius: 8px;
		background: var(--grey-0);
	}

	.award-editor-item input,
	.award-editor-item select {
		width: 100%;
		min-height: 34px;
		border: 0;
		background: transparent;
		color: var(--grey-7);
		font: inherit;
	}

	.award-editor-item input:focus,
	.award-editor-item select:focus {
		outline: 0;
	}

	.award-editor-item select {
		color: var(--color-main);
		font-size: 12px;
		font-family: var(--font-heavy);
	}

	.award-editor-item button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--color-main);
		font-size: 22px;
		line-height: 1;
		cursor: pointer;
	}

	.award-add-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 46px;
		border: 1px dashed var(--color-red-a5);
		border-radius: 8px;
		background: rgba(255, 105, 180, .04);
		color: var(--color-main);
		font-size: 30px;
		font-family: var(--font-light);
		line-height: 1;
		cursor: pointer;
	}

	:global(.award-editor-item) {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 74px 34px;
		gap: 8px;
		align-items: center;
		padding: 8px;
		border: 1px solid var(--color-red-a3);
		border-radius: 8px;
		background: var(--grey-0);
	}

	:global(.award-editor-item input),
	:global(.award-editor-item select) {
		width: 100%;
		min-height: 34px;
		border: 0;
		background: transparent;
		color: var(--grey-7);
		font: inherit;
	}

	:global(.award-editor-item input:focus),
	:global(.award-editor-item select:focus) {
		outline: 0;
	}

	:global(.award-editor-item select) {
		color: var(--color-main);
		font-size: 12px;
		font-family: var(--font-heavy);
	}

	:global(.award-editor-item button) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: var(--color-main);
		font-size: 22px;
		line-height: 1;
		cursor: pointer;
	}

	.panel-note {
		margin: 0;
		color: var(--grey-5);
