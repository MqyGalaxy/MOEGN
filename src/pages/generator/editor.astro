<script>
	import { exportDomToPng } from '../../scripts/exportDomToPng';
	import QRCode from 'qrcode';

	const editor = document.querySelector<HTMLElement>('[data-card-editor]');
	const stage = document.querySelector<HTMLElement>('[data-export-stage]');
	const stageScroll = document.querySelector<HTMLElement>('.stage-scroll');
	const panelToggle = document.querySelector<HTMLButtonElement>('[data-panel-toggle]');
	const panelBackdrop = document.querySelector<HTMLButtonElement>('[data-panel-backdrop]');
	const coverInput = document.querySelector<HTMLInputElement>('[data-cover-input]');
	const coverApply = document.querySelector<HTMLButtonElement>('[data-cover-apply]');
	const exportButton = document.querySelector<HTMLButtonElement>('[data-export-button]');
	const exportStatus = document.querySelector<HTMLElement>('[data-export-status]');
	const exportPreviewModal = document.querySelector<HTMLElement>('[data-export-preview-modal]');
	const exportPreviewHost = document.querySelector<HTMLElement>('[data-export-preview-host]');
	const exportPreviewViewport = document.querySelector<HTMLElement>('.export-preview-viewport');
	const previewDownload = document.querySelector<HTMLButtonElement>('[data-preview-download]');
	const previewClose = document.querySelector<HTMLButtonElement>('[data-preview-close]');
	const qrImage = document.querySelector<HTMLImageElement>('[data-generator-qr]');
	const currentMode = document.querySelector<HTMLElement>('[data-current-mode]');
	const largeAwards = document.querySelector<HTMLElement>('[data-large-awards]');
	const smallAwards = document.querySelector<HTMLElement>('[data-small-awards]');
	const detailAwardHosts = Array.from(document.querySelectorAll<HTMLElement>('[data-detail-awards]'));
	const largeAwardsToggle = document.querySelector<HTMLInputElement>('[data-large-awards-toggle]');
	const largeAwardList = document.querySelector<HTMLElement>('[data-large-award-list]');
	const largeAwardAdd = document.querySelector<HTMLButtonElement>('[data-large-award-add]');

	if (editor && stage && qrImage && exportPreviewModal && exportPreviewHost) {
		const params = new URLSearchParams(window.location.search);
		const styleParam = params.get('style') === 'detail' ? 'detail' : 'classic';
		const sizeParam = params.get('size') === 'small' ? 'small' : 'large';
		const styleLabels = {
			classic: '经典',
			detail: '信息栏',
		};
		const sizeLabels = {
			large: '大卡片',
			small: '小卡片',
		};

		const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

		const clearViewTransform = (target: HTMLElement) => {
			target.style.removeProperty('transform');
			target.style.removeProperty('transform-origin');
			target.style.removeProperty('margin-right');
			target.style.removeProperty('margin-bottom');
		};

		const applyViewTransform = (target: HTMLElement, scale: number) => {
			if (Math.abs(scale - 1) < 0.001) {
				clearViewTransform(target);
				return;
			}

			target.style.transformOrigin = '0 0';
			target.style.transform = `scale(${scale})`;
			target.style.marginRight = `${Math.max(0, target.offsetWidth * (scale - 1))}px`;
			target.style.marginBottom = `${Math.max(0, target.offsetHeight * (scale - 1))}px`;
		};

		const attachPanZoom = (viewport: HTMLElement, getTarget: () => HTMLElement | null) => {
			const state = {
				scale: 1,
				isPanning: false,
				startX: 0,
				startY: 0,
				startScrollLeft: 0,
				startScrollTop: 0,
				pointerId: -1,
			};

			const setScale = (scale: number, originX?: number, originY?: number) => {
				const target = getTarget();
				if (!target) return;

				const nextScale = clamp(scale, 0.35, 3);
				const rect = viewport.getBoundingClientRect();
				const anchorX = originX ?? rect.left + rect.width / 2;
				const anchorY = originY ?? rect.top + rect.height / 2;
				const localX = anchorX - rect.left;
				const localY = anchorY - rect.top;
				const contentX = (viewport.scrollLeft + localX) / state.scale;
				const contentY = (viewport.scrollTop + localY) / state.scale;

				state.scale = nextScale;
				applyViewTransform(target, state.scale);
				viewport.scrollLeft = contentX * state.scale - localX;
				viewport.scrollTop = contentY * state.scale - localY;
			};

			const reset = () => {
				const target = getTarget();

				state.scale = 1;
				if (target) clearViewTransform(target);
				viewport.scrollLeft = 0;
				viewport.scrollTop = 0;
			};

			viewport.addEventListener('wheel', (event) => {
				if (!event.ctrlKey) return;

				event.preventDefault();
				setScale(state.scale + (event.deltaY > 0 ? -0.1 : 0.1), event.clientX, event.clientY);
			}, { passive: false });

			viewport.addEventListener('pointerdown', (event) => {
				if (event.button !== 0) return;

				const interactiveTarget = (event.target as HTMLElement).closest('button, input, select, textarea, a, [contenteditable="true"]');
				if (interactiveTarget) return;

				state.isPanning = true;
				state.pointerId = event.pointerId;
				state.startX = event.clientX;
				state.startY = event.clientY;
				state.startScrollLeft = viewport.scrollLeft;
				state.startScrollTop = viewport.scrollTop;
				viewport.classList.add('is-panning');
				viewport.setPointerCapture(event.pointerId);
			});

			viewport.addEventListener('pointermove', (event) => {
				if (!state.isPanning || event.pointerId !== state.pointerId) return;

				viewport.scrollLeft = state.startScrollLeft - (event.clientX - state.startX);
				viewport.scrollTop = state.startScrollTop - (event.clientY - state.startY);
			});

			const stopPanning = (event: PointerEvent) => {
				if (!state.isPanning || event.pointerId !== state.pointerId) return;

				state.isPanning = false;
				viewport.classList.remove('is-panning');
				if (viewport.hasPointerCapture(event.pointerId)) {
					viewport.releasePointerCapture(event.pointerId);
				}
			};

			viewport.addEventListener('pointerup', stopPanning);
			viewport.addEventListener('pointercancel', stopPanning);

			return { reset };
		};

		if (stageScroll) attachPanZoom(stageScroll, () => stage);
		const previewPanZoom = exportPreviewViewport ? attachPanZoom(exportPreviewViewport, () => getPreviewStage()) : null;

		document.querySelectorAll<HTMLElement>('.panel-block').forEach((block, index) => {
			const heading = block.querySelector<HTMLElement>('h2');

			if (!heading || block.dataset.exportPanel !== undefined) return;

			const panelId = `editor-panel-block-${index}`;
			const shouldCollapse = block.dataset.panelDefaultOpen === undefined;

			block.dataset.collapsible = '';
			heading.setAttribute('role', 'button');
			heading.setAttribute('tabindex', '0');
			heading.setAttribute('aria-expanded', String(!shouldCollapse));
			heading.setAttribute('aria-controls', panelId);
			Array.from(block.children).forEach((child) => {
				if (child !== heading) (child as HTMLElement).dataset.panelContent = panelId;
			});
			if (shouldCollapse) block.classList.add('is-collapsed');

			const toggleBlock = () => {
				const collapsed = block.classList.toggle('is-collapsed');

				heading.setAttribute('aria-expanded', String(!collapsed));
			};

			heading.addEventListener('click', toggleBlock);
			heading.addEventListener('keydown', (event) => {
				if (event.key !== 'Enter' && event.key !== ' ') return;

				event.preventDefault();
				toggleBlock();
			});
		});

		const setMobilePanelOpen = (opened: boolean) => {
			editor.classList.toggle('is-mobile-panel-open', opened);

			const label = opened ? '收起工具栏' : '打开工具栏';
			const text = panelToggle?.querySelector<HTMLElement>('.panel-toggle-text');

			panelToggle?.setAttribute('aria-expanded', String(opened));
			panelToggle?.setAttribute('aria-label', label);
			if (text) text.textContent = label;
		};

		panelToggle?.addEventListener('click', () => {
			setMobilePanelOpen(!editor.classList.contains('is-mobile-panel-open'));
		});

		panelBackdrop?.addEventListener('click', () => {
			setMobilePanelOpen(false);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key !== 'Escape' || !editor.classList.contains('is-mobile-panel-open')) return;

			setMobilePanelOpen(false);
		});

		const updateScoreTagWidth = () => {
			document.querySelectorAll<HTMLElement>('[data-edit-field="scoreTag"]').forEach((field) => {
				const chars = Math.max(Array.from(field.textContent?.trim() || '').length, 1);
				field.style.setProperty('--score-tag-chars', String(chars));
			});
		};

		const createAwardTag = (label: string, tone: string, className: string) => {
			const tag = document.createElement('b');

			tag.className = `${className} is-${tone}`;
			tag.dataset.generatedAward = '';
			tag.textContent = label;

			return tag;
		};

		const createLargeAwardEditor = (label = '新奖项', tone = 'gold') => {
			const item = document.createElement('div');

			item.className = 'award-editor-item';
			item.dataset.largeAwardItem = '';
			item.innerHTML = `
				<input type="text" aria-label="奖项文本" data-large-award-text />
				<select aria-label="奖项等级" data-large-award-tone>
					<option value="gold">金奖</option>
					<option value="silver">银奖</option>
					<option value="bronze">铜奖</option>
				</select>
				<button type="button" aria-label="删除奖项" data-large-award-delete>×</button>
			`;

			const input = item.querySelector<HTMLInputElement>('[data-large-award-text]');
			const select = item.querySelector<HTMLSelectElement>('[data-large-award-tone]');

			if (input) input.value = label;
			if (select) select.value = tone;

			return item;
		};

		const getLargeAwardEditors = () => Array.from(document.querySelectorAll<HTMLElement>('[data-large-award-item]'));

		const getAwardItems = () => getLargeAwardEditors().map((item) => ({
			label: item.querySelector<HTMLInputElement>('[data-large-award-text]')?.value.trim() ?? '',
			tone: item.querySelector<HTMLSelectElement>('[data-large-award-tone]')?.value || 'gold',
		})).filter((item) => item.label);

		const renderLargeAwards = () => {
			const awardItems = largeAwardsToggle?.checked === false ? [] : getAwardItems();

			largeAwards?.replaceChildren(...awardItems.map((item) => createAwardTag(item.label, item.tone, 'pro-cover-award')));
			smallAwards?.replaceChildren(...awardItems.map((item) => createAwardTag(item.label, item.tone, 'pro-award')));

			detailAwardHosts.forEach((host) => {
				host.querySelectorAll('[data-generated-award]').forEach((tag) => tag.remove());

				awardItems.slice().reverse().forEach((item) => {
					host.prepend(createAwardTag(item.label, item.tone, 'detail-award-tag'));
				});
			});
		};

		const createDetailCustomTag = (label = '新标签', id = `tag-${Date.now()}-${Math.random().toString(16).slice(2)}`) => {
			const tag = document.createElement('span');
			const text = document.createElement('span');
			const deleteButton = document.createElement('button');

			tag.className = 'detail-tag';
			tag.dataset.detailTag = '';
			tag.dataset.detailTagId = id;

			text.contentEditable = 'true';
			text.dataset.detailCustomTagText = '';
			text.textContent = label;

			deleteButton.type = 'button';
			deleteButton.dataset.detailTagDelete = '';
			deleteButton.setAttribute('aria-label', '删除标签');
			deleteButton.textContent = '×';

			tag.append(text, deleteButton);

			return tag;
		};

		const insertDetailTagBeforeAddButton = (host: HTMLElement, tag: HTMLElement) => {
			const addButton = host.querySelector<HTMLElement>('[data-detail-tag-add]');

			if (addButton) {
				host.insertBefore(tag, addButton);
			} else {
				host.appendChild(tag);
			}
		};

		const addDetailCustomTag = (sourceHost: HTMLElement) => {
			const id = `tag-${Date.now()}-${Math.random().toString(16).slice(2)}`;
			let focusTarget: HTMLElement | null = null;

			detailAwardHosts.forEach((host) => {
				const tag = createDetailCustomTag('新标签', id);

				insertDetailTagBeforeAddButton(host, tag);

				if (host === sourceHost) {
					focusTarget = tag.querySelector<HTMLElement>('[data-detail-custom-tag-text]');
				}
			});

			if (focusTarget) {
				(focusTarget as HTMLElement).focus();
			}
		};

		const removeMatchingDetailTags = (sourceTag: HTMLElement) => {
			const id = sourceTag.dataset.detailTagId;
			const key = sourceTag.dataset.detailTagKey;

			detailAwardHosts.forEach((host) => {
				host.querySelectorAll<HTMLElement>('[data-detail-tag]').forEach((tag) => {
					if ((id && tag.dataset.detailTagId === id) || (key && tag.dataset.detailTagKey === key)) {
						tag.remove();
					}
				});
			});
		};

		const syncDetailCustomTagText = (sourceText: HTMLElement) => {
			const sourceTag = sourceText.closest<HTMLElement>('[data-detail-tag]');
			const id = sourceTag?.dataset.detailTagId;

			if (!id) return;

			detailAwardHosts.forEach((host) => {
				host.querySelectorAll<HTMLElement>('[data-detail-tag]').forEach((tag) => {
					if (tag.dataset.detailTagId !== id) return;

					const text = tag.querySelector<HTMLElement>('[data-detail-custom-tag-text]');
					if (text && text !== sourceText) text.textContent = sourceText.textContent ?? '';
				});
			});
		};

		const setMode = (modeType: 'style' | 'size', value: string) => {
			stage.dataset[modeType] = value;

			const selector = modeType === 'style' ? '[data-style-option]' : '[data-size-option]';
			document.querySelectorAll<HTMLButtonElement>(selector).forEach((button) => {
				const activeValue = modeType === 'style' ? button.dataset.styleOption : button.dataset.sizeOption;

				button.classList.toggle('is-active', activeValue === value);
			});

			const currentStyle = (stage.dataset.style ?? 'classic') as keyof typeof styleLabels;
			const currentSize = (stage.dataset.size ?? 'large') as keyof typeof sizeLabels;
			const currentVariant = `${currentStyle}-${currentSize}`;

			stage.dataset.variant = currentVariant;

			if (currentMode) {
				currentMode.textContent = `${styleLabels[currentStyle]} / ${sizeLabels[currentSize]}`;
			}
		};

		setMode('style', styleParam);
		setMode('size', sizeParam);
		updateScoreTagWidth();
		renderLargeAwards();

		document.querySelectorAll<HTMLButtonElement>('[data-style-option]').forEach((button) => {
			button.addEventListener('click', () => {
				if (button.dataset.styleOption) setMode('style', button.dataset.styleOption);
			});
		});

		document.querySelectorAll<HTMLButtonElement>('[data-size-option]').forEach((button) => {
			button.addEventListener('click', () => {
				if (button.dataset.sizeOption) setMode('size', button.dataset.sizeOption);
			});
		});

		document.querySelectorAll<HTMLElement>('[data-edit-field]').forEach((field) => {
			field.addEventListener('input', () => {
				const key = field.dataset.editField;
				if (!key) return;

				document.querySelectorAll<HTMLElement>(`[data-edit-field="${key}"]`).forEach((target) => {
					if (target !== field) {
						target.textContent = field.textContent ?? '';
						if (key === 'title') target.setAttribute('title', field.textContent ?? '');
					}
				});

				if (key === 'scoreTag') updateScoreTagWidth();
			});
		});

		largeAwardsToggle?.addEventListener('change', () => {
			largeAwards?.classList.toggle('is-hidden', !largeAwardsToggle.checked);
			smallAwards?.classList.toggle('is-hidden', !largeAwardsToggle.checked);
			renderLargeAwards();
		});

		largeAwardAdd?.addEventListener('click', () => {
			if (!largeAwards || !largeAwardList) return;

			largeAwards.classList.remove('is-hidden');
			smallAwards?.classList.remove('is-hidden');
			if (largeAwardsToggle) largeAwardsToggle.checked = true;
			largeAwardList.appendChild(createLargeAwardEditor());
			renderLargeAwards();
		});

		largeAwardList?.addEventListener('input', renderLargeAwards);
		largeAwardList?.addEventListener('change', renderLargeAwards);
		largeAwardList?.addEventListener('click', (event) => {
			const deleteButton = (event.target as HTMLElement).closest<HTMLElement>('[data-large-award-delete]');

			if (!deleteButton) return;

			deleteButton.closest('[data-large-award-item]')?.remove();
			renderLargeAwards();
		});

		detailAwardHosts.forEach((host) => {
			host.addEventListener('click', (event) => {
				const target = event.target as HTMLElement;
				const addButton = target.closest<HTMLElement>('[data-detail-tag-add]');
				const deleteButton = target.closest<HTMLElement>('[data-detail-tag-delete]');

				if (addButton) {
					addDetailCustomTag(host);
					return;
				}

				if (deleteButton) {
					const tag = deleteButton.closest<HTMLElement>('[data-detail-tag]');

					if (tag) removeMatchingDetailTags(tag);
				}
			});

			host.addEventListener('input', (event) => {
				const text = (event.target as HTMLElement).closest<HTMLElement>('[data-detail-custom-tag-text]');

				if (text) syncDetailCustomTagText(text);
			});
		});

		const colorMap = {
			accent: '--accent',
			accent2: '--accent2',
			paperText: '--paper-text',
			cardBg: '--card-bg',
			cardText: '--card-text',
		};

		const hexToRgba = (hex: string, alpha: number) => {
			const normalized = hex.replace('#', '').trim();
			const fullHex = normalized.length === 3
				? normalized.split('').map((char) => `${char}${char}`).join('')
				: normalized;

			if (!/^[0-9a-fA-F]{6}$/.test(fullHex)) return hex;

			const red = parseInt(fullHex.slice(0, 2), 16);
			const green = parseInt(fullHex.slice(2, 4), 16);
			const blue = parseInt(fullHex.slice(4, 6), 16);

			return `rgba(${red}, ${green}, ${blue}, ${alpha})`;
		};

		const setColor = (name: keyof typeof colorMap, value: string) => {
			stage.style.setProperty(colorMap[name], value);
			if (name === 'accent2') {
				stage.style.setProperty('--accent2-soft', hexToRgba(value, .5));
			}

			const input = document.querySelector<HTMLInputElement>(`[data-color-input="${name}"]`);

			if (input) input.value = value;
		};

		document.querySelectorAll<HTMLInputElement>('[data-color-input]').forEach((input) => {
			input.addEventListener('input', () => {
				const key = input.dataset.colorInput as keyof typeof colorMap | undefined;

				if (key && colorMap[key]) {
					setColor(key, input.value);
				}
			});
		});

		document.querySelectorAll<HTMLButtonElement>('[data-palette]').forEach((button) => {
			button.addEventListener('click', () => {
				const [accent, accent2, paperText, cardBg, cardText] = (button.dataset.palette ?? '').split(',');

				if (accent) setColor('accent', accent);
				if (accent2) setColor('accent2', accent2);
				if (paperText) setColor('paperText', paperText);
				if (cardBg) setColor('cardBg', cardBg);
				if (cardText) setColor('cardText', cardText);
			});
		});

		coverApply?.addEventListener('click', () => {
			const nextCover = coverInput?.value.trim();

			if (nextCover) {
				document.querySelectorAll<HTMLImageElement>('[data-cover-image]').forEach((image) => {
					image.src = nextCover;
				});
			}
		});

		const waitForImage = (image: HTMLImageElement) => new Promise<void>((resolve) => {
			if (image.complete) {
				resolve();
				return;
			}

			image.addEventListener('load', () => resolve(), { once: true });
			image.addEventListener('error', () => resolve(), { once: true });
		});

		const renderQr = async () => {
			qrImage.src = await QRCode.toDataURL(new URL('/generator/', location.origin).href, {
				width: 180,
				margin: 1,
				color: {
					dark: '#ffffff',
					light: '#00000000',
				},
			});
		};

		const downloadBlob = (blob: Blob) => {
			const url = URL.createObjectURL(blob);
			const link = document.createElement('a');
			const styleName = stage.dataset.style ?? 'classic';
			const sizeName = stage.dataset.size ?? 'large';

			link.href = url;
			link.download = `moegn-${styleName}-${sizeName}-card.png`;
			link.style.display = 'none';
			document.body.appendChild(link);
			link.click();
			link.remove();
			window.setTimeout(() => URL.revokeObjectURL(url), 1000);
		};

		const createPreviewStage = () => {
			const clone = stage.cloneNode(true) as HTMLElement;

			clone.classList.add('is-exporting');
			clearViewTransform(clone);
			clone.querySelectorAll<HTMLElement>('[contenteditable="true"]').forEach((editable) => {
				editable.removeAttribute('contenteditable');
			});
			clone.querySelectorAll<HTMLElement>('[data-detail-tag-delete], [data-detail-tag-add]').forEach((control) => {
				control.remove();
			});

			return clone;
		};

		const openPreviewModal = async () => {
			await renderQr();
			await document.fonts?.ready;
			await Promise.all(Array.from(stage.querySelectorAll<HTMLImageElement>('img')).map(waitForImage));

			const previewStage = createPreviewStage();

			exportPreviewHost.replaceChildren(previewStage);
			previewPanZoom?.reset();
			exportPreviewModal.hidden = false;
			document.body.style.overflow = 'hidden';

			await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));
			previewStage.scrollIntoView({ block: 'center', inline: 'center' });
		};

		const closePreviewModal = () => {
			exportPreviewModal.hidden = true;
			exportPreviewHost.replaceChildren();
			document.body.style.overflow = '';
		};

		const getPreviewStage = () => exportPreviewHost.querySelector<HTMLElement>('[data-export-stage]');

		renderQr();

		exportButton?.addEventListener('click', async () => {
			if (!exportButton || !exportStatus) return;

			exportButton.disabled = true;
			exportStatus.textContent = '正在生成图片...';

			try {
				await renderQr();
				await document.fonts?.ready;
				await Promise.all(Array.from(stage.querySelectorAll<HTMLImageElement>('img')).map(waitForImage));
				await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));
				stage.classList.add('is-exporting');
				await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

				const blob = await exportDomToPng(stage, {
					backgroundColor: '#00000000',
					pixelRatio: 2,
					skipAutoScale: true,
					width: stage.offsetWidth,
					height: stage.offsetHeight,
				});

				if (!blob) throw new Error('Export failed');

				downloadBlob(blob);
				exportStatus.textContent = '图片已生成并下载。';
			} catch (error) {
				console.error('MOEGN generator export failed', error);
				exportStatus.textContent = '生成失败，请检查封面图片是否允许跨域，或改用本站打包后的图片路径。';
			} finally {
				stage.classList.remove('is-exporting');
				exportButton.disabled = false;
			}
		});

		exportButton?.addEventListener('click', async (event) => {
			if (!exportButton || !exportStatus) return;

			event.preventDefault();
			event.stopImmediatePropagation();

			exportButton.disabled = true;
			exportStatus.textContent = '正在生成预览...';

			try {
				await openPreviewModal();
				exportStatus.textContent = '预览已生成，请在弹窗中确认并下载。';
			} catch (error) {
				console.error('MOEGN generator preview failed', error);
				exportStatus.textContent = '预览生成失败，请检查封面图片是否可以加载。';
			} finally {
				exportButton.disabled = false;
			}
		}, { capture: true });

		previewDownload?.addEventListener('click', async () => {
			if (!previewDownload || !exportStatus) return;

			const previewStage = getPreviewStage();

			if (!previewStage) {
				exportStatus.textContent = '请先生成预览。';
				return;
			}

			previewDownload.disabled = true;
			let savedViewStyle: { transform: string; transformOrigin: string; marginRight: string; marginBottom: string } | null = null;
			exportStatus.textContent = '正在从预览窗口生成图片...';

			try {
				await document.fonts?.ready;
				await Promise.all(Array.from(previewStage.querySelectorAll<HTMLImageElement>('img')).map(waitForImage));
				await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

				savedViewStyle = {
					transform: previewStage.style.transform,
					transformOrigin: previewStage.style.transformOrigin,
					marginRight: previewStage.style.marginRight,
					marginBottom: previewStage.style.marginBottom,
				};

				clearViewTransform(previewStage);
				await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

				const blob = await exportDomToPng(previewStage, {
					backgroundColor: '#00000000',
					pixelRatio: 2,
					skipAutoScale: true,
					width: previewStage.offsetWidth,
					height: previewStage.offsetHeight,
				});

				previewStage.style.transform = savedViewStyle.transform;
				previewStage.style.transformOrigin = savedViewStyle.transformOrigin;
				previewStage.style.marginRight = savedViewStyle.marginRight;
				previewStage.style.marginBottom = savedViewStyle.marginBottom;

				if (!blob) throw new Error('Export failed');

				downloadBlob(blob);
				exportStatus.textContent = '图片已从预览窗口生成并下载。';
			} catch (error) {
				console.error('MOEGN generator export failed', error);
				exportStatus.textContent = '生成失败，请检查封面图片是否允许跨域，或改用本站打包后的图片路径。';
			} finally {
				if (savedViewStyle) {
					previewStage.style.transform = savedViewStyle.transform;
					previewStage.style.transformOrigin = savedViewStyle.transformOrigin;
					previewStage.style.marginRight = savedViewStyle.marginRight;
					previewStage.style.marginBottom = savedViewStyle.marginBottom;
				}
				previewDownload.disabled = false;
			}
		});

		previewClose?.addEventListener('click', closePreviewModal);

		exportPreviewModal.addEventListener('click', (event) => {
			if (event.target === exportPreviewModal) closePreviewModal();
		});

		window.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !exportPreviewModal.hidden) {
				closePreviewModal();
			}
		});
	}
</script>
